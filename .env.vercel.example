# ── VANDA Portal: Vercel Environment Variables ──
# Copy this to your Vercel project settings under Environment Variables.

# Deploy target (MUST be "vercel" for Vercel deployments)
VITE_DEPLOY_TARGET=vercel

# Database (TiDB / PlanetScale / any MySQL-compatible)
DATABASE_URL=mysql://user:password@host:port/database?ssl={"rejectUnauthorized":true}

# JWT secret for session tokens (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here

# Resend API key for sending PIN emails
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=access@yourdomain.com

# Admin PIN for the admin dashboard (6 digits)
# Note: Currently hardcoded as 314159 in the frontend. 
# To make it configurable, set VITE_ADMIN_PIN here.
